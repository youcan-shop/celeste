{
  "name": "@youcan/celeste-icons",
  "type": "module",
  "version": "0.6.102",
  "author": "YouCan <tech@youcan.shop>",
  "repository": {
    "type": "git",
    "url": "https://github.com/youcan-shop/celeste"
  },
  "keywords": [
    "youcan",
    "celeste"
  ],
  "exports": {
    "./icons.json": "./dist/icons.json",
    "./info.json": "./dist/info.json",
    "./*": "./dist/*",
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      }
    }
  },
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "engines": {
    "node": ">=20.10.0"
  },
  "iconSet": {
    "icons": "./dist/icons.json",
    "info": "./dist/info.json"
  },
  "scripts": {
    "generate-iconify": "tsx scripts/generate-iconify",
    "generate-vue": "tsx scripts/generate-vue.ts",
    "build": "rimraf dist && pnpm generate-iconify && obuild"
  },
  "dependencies": {
    "@iconify/types": "^2.0.0"
  },
  "devDependencies": {
    "@iconify/tools": "^4.2.0",
    "@iconify/utils": "^2.3.0",
    "@svgr/core": "^8.1.0",
    "@types/fs-extra": "^11.0.4",
    "@vue/compiler-dom": "^3.5.39",
    "camelcase": "^8.0.0",
    "fs-extra": "^11.3.6",
    "obuild": "^0.4.37",
    "rimraf": "^6.1.3",
    "svgo": "^3.3.3",
    "tsx": "^4.23.0"
  }
}
