{
  "name": "@youcan/celeste",
  "type": "module",
  "version": "0.6.102",
  "author": "YouCan <tech@youcan.shop>",
  "repository": {
    "type": "git",
    "url": "https://github.com/youcan-shop/celeste"
  },
  "keywords": [
    "youcan",
    "celeste"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/es/index.js",
      "require": "./dist/cjs/index.cjs"
    },
    "./assets/celeste.css": "./dist/celeste.css"
  },
  "main": "./dist/cjs/index.cjs",
  "module": "./dist/es/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src"
  ],
  "engines": {
    "node": ">=20.10.0"
  },
  "scripts": {
    "build": "rimraf dist && vue-tsc --declaration --emitDeclarationOnly -p tsconfig.build.json && vite build",
    "build-only": "vite build",
    "watch": "vite build --watch",
    "type-check": "vue-tsc -p tsconfig.check.json --noEmit",
    "type-gen": "vue-tsc --declaration  --emitDeclarationOnly",
    "test": "vitest",
    "storybook": "NODE_ENV=dev storybook dev -p 6006",
    "build-storybook": "NODE_ENV=dev storybook build"
  },
  "peerDependencies": {
    "vue": "^3.5.13"
  },
  "dependencies": {
    "@tiptap/core": "^3.27.1",
    "@tiptap/extension-bubble-menu": "^3.27.1",
    "@tiptap/extension-color": "^3.27.1",
    "@tiptap/extension-link": "^3.27.1",
    "@tiptap/extension-text-align": "^3.27.1",
    "@tiptap/extension-text-style": "^3.27.1",
    "@tiptap/extensions": "^3.27.1",
    "@tiptap/pm": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "@tiptap/vue-3": "^3.27.1",
    "@vueuse/core": "^14.3.0",
    "@youcan/celeste-icons": "workspace:*",
    "@youcan/celeste-tokens": "workspace:*",
    "clsx": "^2.1.1",
    "reka-ui": "^2.10.1",
    "tinycolor2": "^1.6.0",
    "vue-sonner": "^2.0.9"
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^4.1.3",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@tanstack/vue-table": "^8.21.3",
    "@tsconfig/node20": "^20.1.9",
    "@types/jsdom": "^21.1.7",
    "@types/tinycolor2": "^1.4.6",
    "@typescript-eslint/typescript-estree": "^8.62.1",
    "@typescript-eslint/utils": "^8.62.1",
    "@unocss/reset": "^66.7.4",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/compiler-core": "^3.5.39",
    "@vue/test-utils": "^2.4.11",
    "@vue/tsconfig": "^0.9.1",
    "autoprefixer": "^10.5.2",
    "chromatic": "^11.29.0",
    "eslint-plugin-storybook": "^10.4.6",
    "glob": "^11.1.0",
    "jsdom": "^25.0.1",
    "postcss": "^8.5.16",
    "postcss-nesting": "^13.0.2",
    "rimraf": "^6.1.3",
    "sass": "^1.101.0",
    "storybook": "^10.4.6",
    "unocss": "^66.7.4",
    "vite": "^8.1.3",
    "vite-plugin-dts": "^5.0.3",
    "vitest": "^4.1.9",
    "vue-docgen-api": "^4.79.2",
    "vue-tsc": "^3.3.6"
  }
}
