{
  "name": "celeste",
  "type": "module",
  "version": "0.7.0",
  "private": true,
  "packageManager": "pnpm@11.10.0+sha512.0b7f8b98060031904c017e3a41eb187a16d40eeb829b95c4f8cb03681761fc4ab53dd219115b9b447f4dce1a05a214764461e7d3703392a9f32f9511ce8c86c8",
  "description": "YouCan's design system.",
  "author": "YouCan <tech@youcan.shop>",
  "repository": {
    "type": "git",
    "url": "https://github.com/youcan-shop/celeste"
  },
  "keywords": [
    "youcan",
    "celeste"
  ],
  "scripts": {
    "eslint": "eslint . --cache",
    "eslint:fix": "eslint . --cache --fix",
    "stylelint": "stylelint ./**/*.vue --cache",
    "stylelint:fix": "stylelint ./**/*.vue --cache --fix",
    "lint": "pnpm run eslint && pnpm run stylelint",
    "lint:fix": "pnpm run eslint:fix && pnpm run stylelint:fix",
    "prepare": "pnpm simple-git-hooks",
    "build": "pnpm -r build",
    "bump": "bumpp package.json packages/*/package.json --commit \"chore: release v\" --push --tag",
    "release": "pnpm bump",
    "storybook": "pnpm --filter @youcan/celeste run storybook"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "@types/node": "^26.1.0",
    "@unocss/eslint-plugin": "^66.7.4",
    "@youcan/lint": "^4.0.0",
    "bumpp": "^11.1.0",
    "eslint": "^10.6.0",
    "eslint-plugin-format": "^2.0.1",
    "lint-staged": "^17.0.8",
    "rimraf": "^6.1.3",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.14.0",
    "stylelint-config-property-sort-order-smacss": "^11.2.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-standard-vue": "^1.0.0",
    "typescript": "^6.0.3"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged",
    "commit-msg": "pnpm commitlint --edit ${1}"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
